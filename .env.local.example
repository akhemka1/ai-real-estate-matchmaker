# Frontend (Next.js) environment — copy to .env.local

# Backend API base URL (optional). When set, Google sign-in exchanges the
# Firebase ID token for a backend session via POST /api/v1/auth/firebase.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Google Firebase Web SDK config (enables real "Sign in with Google").
# Get these from Firebase console → Project settings → Your apps → Web app.
# Leave blank to use demo mode (mock Google sign-in).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
