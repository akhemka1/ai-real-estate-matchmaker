# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="AI Real Estate Matchmaker API"
APP_VERSION=1.0.0
ENVIRONMENT=local                 # local | dev | staging | prod
API_V1_PREFIX=/api/v1
DEBUG=false
LOG_JSON=true
LOG_LEVEL=INFO
# Comma-separated or JSON array.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_HOSTS=*                   # set explicit hostnames in production

# ---------------------------------------------------------------------------
# Datastores
# ---------------------------------------------------------------------------
# Local dev defaults to SQLite (no services needed). Use Postgres in prod:
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/real_estate_matchmaker
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=real_estate_matchmaker
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Auth / JWT  (CHANGE THE SECRET BEFORE ANY NON-LOCAL DEPLOYMENT)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=ai-real-estate-matchmaker
JWT_AUDIENCE=ai-real-estate-matchmaker-clients
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------------------------------------------------------
# API keys (B2B integrations)
# ---------------------------------------------------------------------------
API_KEY_PREFIX=resk

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
AI_RATE_LIMIT_PER_MINUTE=30

# ---------------------------------------------------------------------------
# Multi-tenancy / onboarding
# ---------------------------------------------------------------------------
AUTO_PROVISION_ORG_ON_SIGNUP=true
DEFAULT_PLAN=trial

# ---------------------------------------------------------------------------
# AI / LLM (Anthropic Claude) — optional but recommended for production
# When ANTHROPIC_API_KEY is set, AI endpoints use Claude; otherwise they fall
# back to deterministic heuristics so the app always runs.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Default is the most capable model; for high-volume/cost-sensitive workloads
# set claude-haiku-4-5 (cheapest) or claude-sonnet-4-6 (balanced).
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=1024

# ---------------------------------------------------------------------------
# Optional Firebase Admin integration
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=

# ---------------------------------------------------------------------------
# Supabase (stores user logins/credentials)
# ---------------------------------------------------------------------------
# 1) Store all users + credentials in Supabase by setting DATABASE_URL to your
#    Supabase Postgres connection string (Project Settings -> Database), e.g.:
#    DATABASE_URL=postgresql+psycopg://postgres:<password>@db.<ref>.supabase.co:5432/postgres
#    then run: alembic upgrade head
# 2) (Optional) Accept Supabase Auth access tokens at POST /api/v1/auth/supabase
#    by setting the JWT secret (Project Settings -> API -> JWT Secret):
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
